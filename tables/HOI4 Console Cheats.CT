        </CheatEntry>
        <CheatEntry>
          <ID>5</ID>
          <Description>"Add Political Power  =  pp [you enter]  (no in-game ceiling)"</Description>
          <Color>008000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[enable]
{$lua}
if syntaxcheck then return end
if HC and HC.run then
  local n = HC.askAmount("Political Power", "Amount to add (no in-game ceiling):", 1000, 0)
  if n then HC.run("pp " .. n) end
else print("Activate the Console Cheat Engine first.") end
{$asm}
[disable]
</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>6</ID>
          <Description>"Add Manpower  =  manpower [you enter]  (no in-game ceiling)"</Description>
          <Color>008000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[enable]
{$lua}
if syntaxcheck then return end
if HC and HC.run then
  local n = HC.askAmount("Manpower", "Amount to add (no in-game ceiling):", 100000, 0)
  if n then HC.run("manpower " .. n) end
else print("Activate the Console Cheat Engine first.") end
{$asm}
[disable]
</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>7</ID>
          <Description>"Add Army/Navy/Air XP  =  xp [you enter]  (no hard ceiling)"</Description>
          <Color>008000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[enable]
{$lua}
if syntaxcheck then return end
