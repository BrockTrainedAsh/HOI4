      </CheatEntries>
    </CheatEntry>
    <CheatEntry>
      <ID>13</ID>
      <Description>"WASD Camera (toggle) - no AutoHotkey"</Description>
      <Color>800080</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{
 WASD map camera, done entirely in Cheat Engine (no AutoHotkey, no mod).
 While this is ticked AND HOI4 is the active window, holding W/A/S/D pans the
 map by holding the matching arrow key (W=Up, A=Left, S=Down, D=Right). Releasing
 the key stops. It only acts while HOI4 is focused, and it does NOT consume the
 keys elsewhere - so Alt-Tab out and W/A/S/D type normally again.

 Note: while ticked, W/A/S/D also move the camera inside in-game text boxes
 (console / state search). Untick this entry when you need to type in HOI4.
}
[enable]
{$lua}
if syntaxcheck then return end
WC = WC or {}
-- {physical key, arrow it maps to}: W->Up, A->Left, S->Down, D->Right
WC.MAP = { {0x57, 0x26}, {0x41, 0x25}, {0x53, 0x28}, {0x44, 0x27} }
WC.held = {}

function WC.focused()
  local okF, fg = pcall(getForegroundWindow)
  if not okF or not fg or fg == 0 then return false end
  if type(getWindowProcessID) ~= "function" then return false end
  local okP, wpid = pcall(getWindowProcessID, fg)
  if not okP or not wpid then return false end
  return wpid == getOpenedProcessID()
end

WC.timer = createTimer(getMainForm())
WC.timer.Interval = 15
WC.timer.OnTimer = function(timer)
  local active = WC.focused()
  for i = 1, #WC.MAP do
    local letter = WC.MAP[i][1]
    local arrow  = WC.MAP[i][2]
    local pressed = active and isKeyPressed(letter)
    if pressed and not WC.held[arrow] then
      keyDown(arrow); WC.held[arrow] = true
    elseif (not pressed) and WC.held[arrow] then
      keyUp(arrow); WC.held[arrow] = false
    end
  end
end

print("[WASD] camera ON - hold W/A/S/D to pan while HOI4 is focused. Untick to type.")
{$asm}

[disable]
{$lua}
if syntaxcheck then return end
if WC then
  if WC.timer then WC.timer.destroy(); WC.timer = nil end
  for i = 1, #(WC.MAP or {}) do
    local arrow = WC.MAP[i][2]
    if WC.held and WC.held[arrow] then keyUp(arrow) end
  end
  WC.held = {}
  print("[WASD] camera OFF.")
end
WC = nil
{$asm}
</AssemblerScript>
    </CheatEntry>
  </CheatEntries>
</CheatTable>
