          <AssemblerScript>[enable]
{$lua}
if syntaxcheck then return end
if HC and HC.run then
  local n = HC.askAmount("War Support", "Percent to add (in-game ceiling 100):", 50, 0, 100)
  if n then HC.run("ws " .. n) end
else print("Activate the Console Cheat Engine first.") end
{$asm}
