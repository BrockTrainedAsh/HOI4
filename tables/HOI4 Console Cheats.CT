<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="42">
  <CheatEntries>
    <CheatEntry>
      <ID>1</ID>
      <Description>"[ ACTIVATE FIRST ] Console Cheat Engine"</Description>
      <Options moHideChildren="1"/>
      <Color>0000FF</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{
 HOI4 Console Cheats - version-independent.
 Each child cheat sends an in-game console command by simulating keystrokes:
 it opens the console (` key), types the command, presses Enter, closes it.

 HOW TO USE (fixes the old "HOI4 is not the active window" problem):
   1. Tick this engine.
   2. Tick a cheat below. For the "Add ..." cheats you will be asked to type the
      amount yourself - HOI4's real in-game ceiling is enforced where one exists.
   3. ALT-TAB to HOI4. The command is QUEUED and fires automatically the moment
      HOI4 becomes the active window. Several ticked cheats fire in order.

 Works in any non-Ironman game (console is native). For Ironman, enable the
 console first with Fuwa's extension table, then use these.
 If the console does not open, set HC.GRAVE to your keyboard's console key.
 If a command does nothing in-game, that console alias may have changed for your
 version - tell the maintainer and it will be swapped for the canonical form.
}
[enable]
{$lua}
if syntaxcheck then return end
HC = HC or {}
HC.GRAVE = 0xC0   -- the ` / ~ key that opens the HOI4 console (US layout)
HC.ENTER = 0x0D
HC.SHIFT = 0x10

-- character -> virtual key code (covers what console commands need)
HC.vk = { [" "] = 0x20, ["."] = 0xBE, ["-"] = 0xBD, ["/"] = 0xBF }
for i = 0, 25 do HC.vk[string.char(97 + i)] = 0x41 + i end  -- a-z
for i = 0, 9  do HC.vk[string.char(48 + i)] = 0x30 + i end  -- 0-9
HC.shiftChars = { ["_"] = 0xBD }  -- underscore = Shift + '-'

HC.queue = HC.queue or {}

-- True only when the REAL foreground window belongs to hoi4.exe.
function HC.focused()
  local okF, fg = pcall(getForegroundWindow)
  if not okF or not fg or fg == 0 then return false end
  if type(getWindowProcessID) ~= "function" then return true end
  local okP, wpid = pcall(getWindowProcessID, fg)
  if not okP or not wpid then return true end
  return wpid == getOpenedProcessID()
end

-- Ask the user for an amount. lo/hi are optional in-game ceilings (clamped).
-- Returns an integer, or nil if cancelled / not a number.
function HC.askAmount(title, prompt, default, lo, hi)
  local s = inputQuery("Console Cheats: " .. title, prompt, tostring(default))
  if s == nil then return nil end
  local n = tonumber(s)
  if n == nil then print("[Console Cheats] '" .. tostring(s) .. "' is not a number."); return nil end
  n = math.floor(n)
  if lo ~= nil then n = math.max(n, lo) end
  if hi ~= nil then
    local capped = math.min(n, hi)
    if capped ~= n then print("[Console Cheats] capped to in-game max " .. hi .. ".") end
    n = capped
  end
  return n
end

function HC.tap(vk)
  keyDown(vk); sleep(12); keyUp(vk); sleep(14)
end

function HC.typeChar(c)
  local sv = HC.shiftChars[c]
  if sv then
    keyDown(HC.SHIFT); sleep(8)
    keyDown(sv); sleep(12); keyUp(sv); sleep(8)
    keyUp(HC.SHIFT); sleep(12)
    return
  end
  local vk = HC.vk[c]
  if vk then HC.tap(vk) end
end

function HC.typeString(s)
  for i = 1, #s do HC.typeChar(string.sub(s, i, i)) end
end

-- Actually push the keystrokes (assumes HOI4 is already focused).
function HC.send(cmd)
  HC.tap(HC.GRAVE); sleep(140)   -- open console
  HC.typeString(cmd); sleep(90)
  HC.tap(HC.ENTER); sleep(90)    -- execute
  HC.tap(HC.GRAVE)               -- close console
  print("[Console Cheats] sent: " .. cmd)
end

-- One background dispatcher drains the queue, one command at a time, but only
-- while HOI4 is the active window. This is what lets you tick-then-Alt-Tab.
function HC.ensureDispatcher()
  if HC.dispatcher then return end
  HC.dispatcher = createTimer(getMainForm())
  HC.dispatcher.Interval = 200
  HC.dispatcher.OnTimer = function(timer)
    if #HC.queue == 0 then return end
    if not HC.focused() then return end
    local cmd = table.remove(HC.queue, 1)
    HC.send(cmd)
  end
end

-- Child cheats call this. Queue the command; it fires when HOI4 is focused.
function HC.run(cmd)
  table.insert(HC.queue, cmd)
  HC.ensureDispatcher()
  if HC.focused() then
    print("[Console Cheats] queued: " .. cmd)
  else
    print("[Console Cheats] queued: " .. cmd .. " - Alt-Tab to HOI4 to fire it.")
  end
  return true
end

print("[Console Cheats] engine ready. Tick a cheat, then Alt-Tab to HOI4.")
{$asm}

[disable]
{$lua}
if syntaxcheck then return end
if HC and HC.dispatcher then HC.dispatcher.destroy() end
HC = nil
{$asm}
</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>2</ID>
          <Description>"Instant Construction (toggle)  =  instantconstruction"</Description>
          <Color>008000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[enable]
{$lua}
if syntaxcheck then return end
if HC and HC.run then HC.run("instantconstruction") else print("Activate the Console Cheat Engine first.") end
{$asm}
[disable]
</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>3</ID>
