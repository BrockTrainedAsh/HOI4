<?xml version="1.0" encoding="utf-8"?>
<CheatTable CheatEngineTableVersion="42">
  <CheatEntries>
    <CheatEntry>
      <ID>1</ID>
      <Description>"[ ACTIVATE FIRST ] Console Cheat Engine"</Description>
      <Options moHideChildren="1"/>
      <Color>0000FF</Color>
      <VariableType>Auto Assembler Script</VariableType>
      <AssemblerScript>{
 HOI4 Console Cheats - version-independent, now with full logging.
 Each child cheat sends an in-game console command by simulating keystrokes:
 it opens the console (` key), types the command, presses Enter, closes it.

 HOW TO USE:
   1. Tick this engine.
   2. Tick a cheat below (you will be prompted for amounts on the "Add" cheats).
   3. ALT-TAB to HOI4. The command is QUEUED and fires the moment HOI4 is active.

 IF SOMETHING DOES NOT WORK: tick "[ DIAGNOSTICS ] ..." at the bottom, Alt-Tab to
 HOI4 for ~8 seconds, then send the log. EVERY step is written to:
   HC.LOGFILE (see below) AND printed in this Lua Engine window.
 Read/tail it with:  python3 tools/ce_log_watch.py
}
[enable]
{$lua}
if syntaxcheck then return end
HC = HC or {}
HC.GRAVE = 0xC0   -- ` / ~ key that opens the HOI4 console (US layout). Change if needed.
HC.ENTER = 0x0D
HC.SHIFT = 0x10
-- Where the step-by-step log is written. Change the path if your repo differs.
HC.LOGFILE = HC.LOGFILE or [[C:\Users\Brock\Documents\My Cheat Tables\HOI4-Memory-Toolkit\logs\ce-console.log]]

-- Timestamped log line -> both the Lua Engine window AND the log file.
function HC.log(msg)
  local line = "[" .. os.date("%H:%M:%S") .. "] " .. tostring(msg)
  print(line)
  pcall(function()
    local f = io.open(HC.LOGFILE, "a")
    if f then f:write(line .. "\n"); f:close() end
  end)
end

-- character -> virtual key code (covers what console commands need)
HC.vk = { [" "] = 0x20, ["."] = 0xBE, ["-"] = 0xBD, ["/"] = 0xBF }
for i = 0, 25 do HC.vk[string.char(97 + i)] = 0x41 + i end  -- a-z
for i = 0, 9  do HC.vk[string.char(48 + i)] = 0x30 + i end  -- 0-9
HC.shiftChars = { ["_"] = 0xBD }  -- underscore = Shift + '-'

HC.queue = HC.queue or {}

-- True only when the REAL foreground window belongs to hoi4.exe.
function HC.focused()
  local okF, fg = pcall(getForegroundWindow)
  if not okF or not fg or fg == 0 then return false end
  if type(getWindowProcessID) ~= "function" then return true end
  local okP, wpid = pcall(getWindowProcessID, fg)
  if not okP or not wpid then return true end
  return wpid == getOpenedProcessID()
end

-- One-shot environment dump so we can see WHY a cheat is not landing.
function HC.diag()
  HC.log("===== DIAGNOSTICS =====")
  HC.log("CE version: " .. tostring(type(getCEVersion) == "function" and getCEVersion() or "?"))
  local pid = getOpenedProcessID()
  HC.log("attached process: " .. tostring(process) .. "  pid: " .. tostring(pid))
  if pid == nil or pid == 0 then HC.log("WARNING: not attached to a process! Open hoi4.exe in CE first.") end
  HC.log("API present? getForegroundWindow=" .. type(getForegroundWindow)
    .. " getWindowProcessID=" .. type(getWindowProcessID)
    .. " isKeyPressed=" .. type(isKeyPressed)
    .. " inputQuery=" .. type(inputQuery)
    .. " createTimer=" .. type(createTimer))
  local okF, fg = pcall(getForegroundWindow)
  HC.log("foreground handle: " .. tostring(okF and fg or "ERR"))
  if okF and fg and fg ~= 0 and type(getWindowProcessID) == "function" then
    local okP, wp = pcall(getWindowProcessID, fg)
    HC.log("foreground pid: " .. tostring(okP and wp or "ERR")
      .. "  HOI4 pid: " .. tostring(pid)
      .. "  MATCH: " .. tostring(okP and wp == pid))
  end
  HC.log("logfile: " .. tostring(HC.LOGFILE))
end

function HC.tap(vk)
  keyDown(vk); sleep(12); keyUp(vk); sleep(14)
end

function HC.typeChar(c)
  local sv = HC.shiftChars[c]
  if sv then
    keyDown(HC.SHIFT); sleep(8)
    keyDown(sv); sleep(12); keyUp(sv); sleep(8)
    keyUp(HC.SHIFT); sleep(12)
    return
  end
  local vk = HC.vk[c]
  if vk then HC.tap(vk) end
end

function HC.typeString(s)
  for i = 1, #s do HC.typeChar(string.sub(s, i, i)) end
end

-- Ask the user for an amount. lo/hi are optional in-game ceilings (clamped).
function HC.askAmount(title, prompt, default, lo, hi)
  local s = inputQuery("Console Cheats: " .. title, prompt, tostring(default))
  if s == nil then HC.log(title .. ": cancelled"); return nil end
  local n = tonumber(s)
  if n == nil then HC.log(title .. ": '" .. tostring(s) .. "' is not a number"); return nil end
  n = math.floor(n)
  if lo ~= nil then n = math.max(n, lo) end
  if hi ~= nil then
    local capped = math.min(n, hi)
    if capped ~= n then HC.log(title .. ": capped to in-game max " .. hi) end
    n = capped
  end
  return n
end

-- Actually push the keystrokes (assumes HOI4 is already focused).
function HC.send(cmd)
  HC.log("send: opening console (GRAVE 0x" .. string.format("%X", HC.GRAVE) .. ")")
  HC.tap(HC.GRAVE); sleep(140)
  HC.log("send: typing '" .. cmd .. "'")
  HC.typeString(cmd); sleep(90)
  HC.tap(HC.ENTER); sleep(90)
  HC.tap(HC.GRAVE)
  HC.log("send: DONE '" .. cmd .. "' (if nothing changed in-game: wrong console key or command)")
end

-- One background dispatcher drains the queue while HOI4 is the active window.
function HC.ensureDispatcher()
  if HC.dispatcher then return end
  HC._lastDispFocus = nil
  HC.dispatcher = createTimer(getMainForm())
  HC.dispatcher.Interval = 200
  HC.dispatcher.OnTimer = function(timer)
    if #HC.queue == 0 then return end
    local f = HC.focused()
    if f ~= HC._lastDispFocus then
      HC.log("dispatcher: HOI4 focused=" .. tostring(f) .. " (queued=" .. #HC.queue .. ")")
      HC._lastDispFocus = f
    end
    if not f then return end
    local cmd = table.remove(HC.queue, 1)
    HC.send(cmd)
  end
end

-- Child cheats call this. Queue the command; it fires when HOI4 is focused.
function HC.run(cmd)
  table.insert(HC.queue, cmd)
  HC.ensureDispatcher()
  HC.log("queued: '" .. cmd .. "' - Alt-Tab to HOI4 to fire (queue=" .. #HC.queue .. ")")
  return true
end

HC.log("engine ready. Tick a cheat, then Alt-Tab to HOI4. Logging to " .. HC.LOGFILE)
{$asm}

[disable]
{$lua}
if syntaxcheck then return end
if HC then
  if HC.dispatcher then HC.dispatcher.destroy() end
  if HC.log then HC.log("engine disabled.") end
end
HC = nil
{$asm}
</AssemblerScript>
      <CheatEntries>
        <CheatEntry>
          <ID>2</ID>
          <Description>"Instant Construction (toggle)  =  instantconstruction"</Description>
          <Color>008000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[enable]
{$lua}
if syntaxcheck then return end
if HC and HC.run then HC.run("instantconstruction") else print("Activate the Console Cheat Engine first.") end
{$asm}
[disable]
</AssemblerScript>
        </CheatEntry>
        <CheatEntry>
          <ID>3</ID>
          <Description>"Instant National Focus (toggle)  =  focus.autocomplete"</Description>
          <Color>008000</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>[enable]
{$lua}
